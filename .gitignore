# ─────────────────────────────────────────────────────────────────
#  Plumb · .gitignore
#  Anything generated by ./build.sh, ./run.sh, an editor, an OS, or
#  the platform's package manager has no business being in the repo.
#  Everything that *is* tracked stays explicit (see "Allow" sections).
# ─────────────────────────────────────────────────────────────────

# ── 1. Build artefacts ───────────────────────────────────────────
# Generated by `./build.sh` (CMake out-of-source build) and the
# CMake configure step. None of these belong in git.
build/
out/
cmake-build-*/
.cmake/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
CTestTestfile.cmake
cmake_install.cmake
install_manifest.txt
Makefile
*.cmake
!src/CMakeLists.txt
!src/**/*.cmake
compile_commands.json
.ninja_deps
.ninja_log
build.ninja

# ── 2. Pass run outputs ──────────────────────────────────────────
# `./run.sh` regenerates these deterministically — they are CI
# artefacts, not source. Keeping them out of git also stops merge
# conflicts in the JSON every time a weight is tweaked.
ir/
results/
*.json.tmp
*.csv.tmp

# Benchmark sweep against LLVM test-suite — the cloned suite is
# ~30 MB of upstream code and its IR/results explode in size.
benchmarks/llvm-test-suite/
benchmarks/ir/
benchmarks/results/
benchmarks/run.log
# DO track the harness scripts and the auto-generated SUMMARY.md.
!benchmarks/SUMMARY.md
!benchmarks/*.sh
!benchmarks/*.py

# ── 3. Compiled binaries / object files ──────────────────────────
# Both Linux (.so) and macOS (.dylib) loadable LLVM modules, and
# every form of object/archive/intermediate the toolchain emits.
*.o
*.obj
*.a
*.la
*.lo
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.dSYM/
*.pdb
*.exp
*.ilk
*.idb

# ── 4. LLVM IR / bitcode artefacts ───────────────────────────────
# Loose .ll / .bc files at the top level are typically stray probes
# from manual `opt`/`clang` invocations. Tracked IR (if any) lives
# under testcases/ as .c sources; the .ll is regenerated.
*.ll
*.bc
*.s
*.S
!testcases/**/*.ll
!testcases/**/*.bc

# ── 5. Profile / sanitiser / coverage outputs ────────────────────
*.profraw
*.profdata
*.gcda
*.gcno
*.gcov
coverage/
lcov.info
*.lcov
.afl/
sanitizer-*.log
asan.log.*
ubsan.log.*
msan.log.*
tsan.log.*

# ── 6. Editor & IDE state ────────────────────────────────────────
# VS Code / Kiro / JetBrains / Vim / Emacs / Sublime / Xcode.
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*.swn
*~
*.bak
.\#*
\#*\#
.netrwhist
Session.vim
.cursor/
.kiro/cache/
*.code-workspace
*.sublime-project
*.sublime-workspace
.xcodeproj/
*.xccheckout
*.xcscmblueprint
.tags
tags
TAGS
.cache/
.ccls-cache/
.clangd/
.clang-format-bak

# ── 7. OS / filesystem cruft ─────────────────────────────────────
# macOS Finder / Spotlight / Trash, Linux trash, Windows thumbs.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
Icon?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── 8. Logs / diagnostics ────────────────────────────────────────
*.log
*.log.*
logs/
debug.txt
crash.txt
core
core.*

# ── 9. Python cruft (used by helper scripts in evaluation) ───────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.coverage
.coverage.*
htmlcov/
.venv/
venv/
env/

# ── 10. Node / dashboard tooling (in case anyone bundles later) ──
# The dashboard ships as a single HTML; if a future iteration adds
# a build step (npm/pnpm/bun), these will already be ignored.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/
.parcel-cache/
.next/
.nuxt/
dist/
.bundle/

# ── 11. Secrets / local environment ──────────────────────────────
# Defensive — this project doesn't currently take any secrets, but
# keep this list ahead of any future feature drift.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets.yml
.secrets/

# ── 12. Local override scratch ───────────────────────────────────
# A place to keep local notes, scratch test inputs, experimental
# weight configs etc. without committing them.
scratch/
TODO.local.md
NOTES.local.md
.local/

# ── 13. Allow-list (unignore things globs would otherwise eat) ───
# These files MUST be tracked. Listing them after the broad globs
# means they survive the wildcards above.
!.gitignore
!.gitattributes
!config/weights.cfg
!docs/screenshots/README.md
!testcases/*.c
